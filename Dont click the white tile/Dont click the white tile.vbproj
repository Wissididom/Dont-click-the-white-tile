<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <RootNamespace>Dont_click_the_white_tile</RootNamespace>
    <AssemblyName>Dont_click_the_white_tile</AssemblyName>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <StartupObject>Dont_click_the_white_tile.frmGame</StartupObject>
    <ApplicationIcon>dctwt_Icon.ico</ApplicationIcon>
  </PropertyGroup>

</Project>
